# Terraform working directory
.terraform/

# Terraform state
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Variable files (often contain secrets)
*.tfvars
*.tfvars.json

# CLI config files
.terraformrc
terraform.rc

# Terraform lock file
# Keep this if you want reproducible provider versions
# Ignore it only if your team policy requires
# .terraform.lock.hcl

# Plan files
*.tfplan
*.plan

# Backend HCL files
backend-*.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# IDE files
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db
